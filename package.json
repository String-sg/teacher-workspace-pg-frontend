    "@types/react-dom": "19.2.3",
    "@vitest/ui": "^4.1.8",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "shadcn": "^4.11.0",
